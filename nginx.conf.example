server {
    listen 80;
    listen [::]:80;
    server_name codebite.yourdomain.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name codebite.yourdomain.com;
    
    root /var/www/codebite/public;
    index index.php index.html index.htm;

    # SSL Configuration (assuming Let's Encrypt / Certbot)
    ssl_certificate /etc/letsencrypt/live/codebite.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/codebite.yourdomain.com/privkey.pem;
    
    # Main Laravel App
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Pass PHP scripts to FastCGI server
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock; # Adjust PHP version as needed
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }
    
    # Laravel Reverb WebSocket Proxy (ws:// to port 8080)
    location /app {
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Scheme $scheme;
        proxy_set_header SERVER_PORT $server_port;
        proxy_set_header REMOTE_ADDR $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_pass http://127.0.0.1:8080;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
